<group name="local,">

  <rule id="100002" level="5">
    <if_sid>80700</if_sid>
    <field name="audit.command" type="pcre2">^(chmod|chown|whoami|ls|id|sudo|adduser|passwd|nmap|netstat|ncat|adduser|useradd|deluser)$</field>
    <field name="audit.auid" negate="yes" type="pcre2">^(4294967295|0)$</field> 
    <description>AUDIT: COMANDO SENSÍVEL DIGITADO PELO USUÁRIO: $(audit.command)</description>
    <group>auditd,command,</group>
  </rule>

  <rule id="100004" level="0">
    <if_sid>80730</if_sid>
    <description>Eliminando ruído.</description>
  </rule>
   
</group>
